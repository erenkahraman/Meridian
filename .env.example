# Supabase (server-side only — used by /scripts and Next.js server routes,
# never exposed to the client bundle). SUPABASE_SECRET_KEY is Supabase's
# current name for the privileged key (older projects: SUPABASE_SERVICE_ROLE_KEY,
# which is also accepted).
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# LLM provider (Phase 1 is Gemini-only by design; keep this the only
# provider key until a second model is deliberately added)
GEMINI_API_KEY=

# Optional overrides (sensible defaults are used if unset)
# LLM_PROVIDER=gemini
# GEMINI_MODEL=gemini-2.5-flash
